generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Alliance {
  IMPERIAL
  CHAOS
  XENOS
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum Rank {
  STONE_I
  STONE_II
  STONE_III
  IRON_I
  IRON_II
  IRON_III
  BRONZE_I
  BRONZE_II
  BRONZE_III
  SILVER_I
  SILVER_II
  SILVER_III
  GOLD_I
  GOLD_II
  GOLD_III
  DIAMOND_I
  DIAMOND_II
  DIAMOND_III
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  HOLD
}

enum InvestmentStatus {
  INVEST_NOW
  CAMPAIGN_PRIORITY
  GUILD_RAID_PRIORITY
  ARENA_PRIORITY
  EVENT_PRIORITY
  MAINTAIN
  IGNORE_FOR_NOW
}

enum TeamMode {
  ARENA
  GUILD_RAID
  GUILD_WAR
  SALVAGE_RUN
  ONSLAUGHT
  CHARACTER_EVENT
  INDOMITUS
  INDOMITUS_MIRROR
  FALL_OF_CADIA
  FALL_OF_CADIA_MIRROR
  OCTARIUS
  OCTARIUS_MIRROR
  SAIM_HANN
  SAIM_HANN_MIRROR
  OTHER
}

enum GoalStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum TacticusConnectionStatus {
  CONNECTED
  SYNCING
  ERROR
}

enum TacticusSyncStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum UnitType {
  CHARACTER
  MACHINE_OF_WAR
  UNKNOWN
}

enum UnitTypeSource {
  VERIFIED_MAPPING
  MANUAL
  UNKNOWN
}

enum UnitTypeConfidence {
  CONFIRMED
  HIGH
  UNKNOWN
}

enum ResourceType {
  EQUIPMENT
  UPGRADE_MATERIAL
  SHARD
  MYTHIC_SHARD
  XP_BOOK
  ABILITY_BADGE
  COMPONENT
  FORGE_BADGE
  ORB
  REQUISITION_ORDER
  RESET_STONE
  UNKNOWN
}

enum ResourceSemanticStatus {
  VERIFIED
  PARTIAL
  UNKNOWN
}

enum VerificationStatus {
  VERIFIED
  NOT_APPLICABLE
  NEEDS_REVIEW
}

enum CampaignType {
  STANDARD
  MIRROR
  ELITE
  EVENT
  UNKNOWN
}

enum EventType {
  LEGENDARY_EVENT
  CAMPAIGN_EVENT
  QUEST
  SURVIVAL
  INCURSION
  UNKNOWN
}

enum ProgressSemanticStatus {
  VERIFIED
  PARTIAL
  UNKNOWN
  UNSUPPORTED
}

enum PlanStatus {
  NOT_STARTED
  ACTIVE
  BLOCKED
  PAUSED
  COMPLETED
  NEEDS_REVIEW
}

model Character {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  faction                String
  alliance               Alliance
  rarity                 Rarity?
  starLevel              Int?
  redStarLevel           Int?
  characterLevel         Int?
  rank                   Rank?
  rankProgress           Int?
  activeAbilityLevel     Int?
  passiveAbilityLevel    Int?
  shardsOwned            Int?
  shardsRequired         Int?
  mythicShardsOwned      Int?
  externalCharacterId    String?                 @unique
  externalDefinitionId   String?
  syncSource             String?
  lastSyncedAt           DateTime?
  upstreamUpdatedAt      DateTime?
  unitType               UnitType                @default(UNKNOWN)
  unitTypeSource         UnitTypeSource          @default(UNKNOWN)
  unitTypeConfidence     UnitTypeConfidence      @default(UNKNOWN)
  priority               Priority                @default(MEDIUM)
  investmentStatus       InvestmentStatus        @default(MAINTAIN)
  notes                  String?
  isOwned                Boolean                 @default(true)
  portraitUrl            String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  teamMembers            TeamMember[]
  upgradeGoals           UpgradeGoal[]
  changes                CharacterChange[]
  readinessVerifications ReadinessVerification[]

  @@index([lastSyncedAt])
}

model Team {
  id            String         @id @default(cuid())
  name          String
  mode          TeamMode
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  teamMembers   TeamMember[]
  campaignPlans CampaignPlan[]
  eventPlans    EventPlan[]
}

model TeamMember {
  id          String    @id @default(cuid())
  teamId      String
  characterId String
  position    Int
  role        String?
  notes       String?
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([teamId, position])
  @@unique([teamId, characterId])
}

model UpgradeGoal {
  id                        String     @id @default(cuid())
  characterId               String
  targetRank                Rank?
  targetRarity              Rarity?
  targetCharacterLevel      Int?
  targetActiveAbilityLevel  Int?
  targetPassiveAbilityLevel Int?
  priority                  Priority
  reason                    String?
  status                    GoalStatus @default(PLANNED)
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  character                 Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model TacticusConnection {
  id                    String                   @id @default(cuid())
  userId                String?
  encryptedApiKey       String
  encryptionIv          String
  encryptionAuthTag     String
  encryptionVersion     Int                      @default(1)
  keyFingerprint        String                   @unique
  status                TacticusConnectionStatus @default(CONNECTED)
  externalPlayerId      String?
  externalPlayerName    String?
  scopesJson            String?
  upstreamLastUpdatedAt DateTime?
  lastAttemptedSyncAt   DateTime?
  lastSuccessfulSyncAt  DateTime?
  lastErrorCode         String?
  lastErrorMessage      String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  syncRuns              TacticusSyncRun[]
  previews              TacticusSyncPreview[]
  snapshots             RosterSnapshot[]
}

model TacticusPendingConnection {
  id                    String   @id @default(cuid())
  userId                String?
  encryptedApiKey       String
  encryptionIv          String
  encryptionAuthTag     String
  encryptionVersion     Int      @default(1)
  keyFingerprint        String
  confirmationTokenHash String   @unique
  externalPlayerName    String
  scopesJson            String
  upstreamLastUpdatedAt DateTime
  unitCount             Int      @default(0)
  inventoryRecordCount  Int      @default(0)
  expiresAt             DateTime
  createdAt             DateTime @default(now())
}

model TacticusSyncRun {
  id                    String             @id @default(cuid())
  connectionId          String
  status                TacticusSyncStatus
  startedAt             DateTime           @default(now())
  completedAt           DateTime?
  upstreamLastUpdatedAt DateTime?
  responseSchemaVersion String?
  recordsReceived       Int                @default(0)
  errorCode             String?
  errorMessage          String?
  connection            TacticusConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  snapshots             RosterSnapshot[]

  @@index([connectionId, startedAt])
}

model TacticusSyncPreview {
  id                    String             @id @default(cuid())
  connectionId          String
  tokenHash             String             @unique
  playerIdentity        String
  upstreamLastUpdatedAt DateTime
  payloadJson           String
  expiresAt             DateTime
  createdAt             DateTime           @default(now())
  connection            TacticusConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
}

model InventoryItem {
  id                   String                 @id @default(cuid())
  externalInventoryId  String                 @unique
  displayName          String?
  category             String
  resourceType         ResourceType           @default(UNKNOWN)
  resourceSubtype      String?
  allianceRestriction  String?
  semanticStatus       ResourceSemanticStatus @default(UNKNOWN)
  externalResourceId   String?
  rarity               String?
  quantity             Int
  upstreamMetadataJson String?
  lastSyncedAt         DateTime
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  changes              InventoryChange[]

  @@index([lastSyncedAt])
}

model ReadinessVerification {
  id              String             @id @default(cuid())
  key             String             @unique
  characterId     String?
  opportunityType String
  status          VerificationStatus @default(NEEDS_REVIEW)
  note            String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  character       Character?         @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([status])
}

model RosterSnapshot {
  id                    String                   @id @default(cuid())
  connectionId          String
  syncRunId             String
  identity              String                   @unique
  upstreamLastUpdatedAt DateTime
  characterCount        Int
  inventoryCount        Int
  campaignCount         Int                      @default(0)
  eventCount            Int                      @default(0)
  createdAt             DateTime                 @default(now())
  connection            TacticusConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  syncRun               TacticusSyncRun          @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  characterChanges      CharacterChange[]
  inventoryChanges      InventoryChange[]
  campaignChanges       CampaignProgressChange[]
  eventChanges          EventProgressChange[]

  @@index([syncRunId])
}

model CampaignDefinition {
  id                   String                   @id @default(cuid())
  externalKey          String                   @unique
  externalCampaignId   String
  displayName          String
  displayNameSource    String                   @default("API")
  upstreamType         String
  normalizedType       CampaignType
  typeSource           String
  confidence           String
  semanticStatus       ProgressSemanticStatus
  isActive             Boolean?
  startsAt             DateTime?
  endsAt               DateTime?
  upstreamMetadataJson String?
  lastSyncedAt         DateTime
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  progress             CampaignProgress?
  plan                 CampaignPlan?
  changes              CampaignProgressChange[]

  @@index([externalCampaignId])
  @@index([normalizedType, semanticStatus])
  @@index([isActive, endsAt])
  @@index([lastSyncedAt])
}

model CampaignProgress {
  id                    String             @id @default(cuid())
  campaignId            String             @unique
  battleRecordCount     Int
  completedNodes        Int?
  totalNodes            Int?
  earnedStars           Int?
  availableStars        Int?
  currentNode           String?
  highestUnlockedNode   String?
  lastCompletedNode     String?
  rawProgressJson       String
  upstreamLastUpdatedAt DateTime
  lastSyncedAt          DateTime
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  campaign              CampaignDefinition @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignPlan {
  id               String               @id @default(cuid())
  campaignId       String               @unique
  status           PlanStatus           @default(NEEDS_REVIEW)
  priority         Priority             @default(MEDIUM)
  currentObjective String?
  targetObjective  String?
  blockerSummary   String?
  strategyNotes    String?
  preferredTeamId  String?
  targetDate       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  campaign         CampaignDefinition   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  preferredTeam    Team?                @relation(fields: [preferredTeamId], references: [id], onDelete: SetNull)
  changes          CampaignPlanChange[]

  @@index([status, priority])
  @@index([preferredTeamId])
}

model CampaignPlanChange {
  id             String       @id @default(cuid())
  campaignPlanId String
  field          String
  previousValue  String?
  newValue       String?
  createdAt      DateTime     @default(now())
  campaignPlan   CampaignPlan @relation(fields: [campaignPlanId], references: [id], onDelete: Cascade)

  @@index([campaignPlanId, createdAt])
}

model CampaignProgressChange {
  id            String             @id @default(cuid())
  snapshotId    String
  campaignId    String
  externalId    String
  field         String
  previousValue String?
  newValue      String?
  createdAt     DateTime           @default(now())
  snapshot      RosterSnapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  campaign      CampaignDefinition @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([snapshotId])
}

model EventDefinition {
  id                   String                 @id @default(cuid())
  externalKey          String                 @unique
  externalEventId      String
  displayName          String
  displayNameSource    String                 @default("API")
  eventType            EventType
  typeSource           String
  confidence           String
  semanticStatus       ProgressSemanticStatus
  isActive             Boolean?
  startsAt             DateTime?
  endsAt               DateTime?
  upstreamMetadataJson String?
  lastSyncedAt         DateTime
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  progress             EventProgress?
  plan                 EventPlan?
  changes              EventProgressChange[]

  @@index([externalEventId])
  @@index([eventType, semanticStatus])
  @@index([isActive, endsAt])
  @@index([lastSyncedAt])
}

model EventProgress {
  id                       String          @id @default(cuid())
  eventId                  String          @unique
  currentPoints            Int?
  currentCurrency          Int
  currentShards            Int
  currentClaimedChestIndex Int
  laneCount                Int
  completedMilestones      Int?
  totalMilestones          Int?
  currentStage             String?
  tokensCurrent            Int?
  tokensMax                Int?
  nextTokenInSeconds       Int?
  tokenRegenDelay          Int?
  rawProgressJson          String
  upstreamLastUpdatedAt    DateTime
  lastSyncedAt             DateTime
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  event                    EventDefinition @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventPlan {
  id               String            @id @default(cuid())
  eventId          String            @unique
  status           PlanStatus        @default(NEEDS_REVIEW)
  priority         Priority          @default(MEDIUM)
  currentObjective String?
  targetObjective  String?
  blockerSummary   String?
  strategyNotes    String?
  preferredTeamId  String?
  targetDate       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  event            EventDefinition   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  preferredTeam    Team?             @relation(fields: [preferredTeamId], references: [id], onDelete: SetNull)
  changes          EventPlanChange[]

  @@index([status, priority])
  @@index([preferredTeamId])
}

model EventPlanChange {
  id            String    @id @default(cuid())
  eventPlanId   String
  field         String
  previousValue String?
  newValue      String?
  createdAt     DateTime  @default(now())
  eventPlan     EventPlan @relation(fields: [eventPlanId], references: [id], onDelete: Cascade)

  @@index([eventPlanId, createdAt])
}

model EventProgressChange {
  id            String          @id @default(cuid())
  snapshotId    String
  eventId       String
  externalId    String
  field         String
  previousValue String?
  newValue      String?
  createdAt     DateTime        @default(now())
  snapshot      RosterSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  event         EventDefinition @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([snapshotId])
}

model CharacterChange {
  id            String         @id @default(cuid())
  snapshotId    String
  characterId   String
  externalId    String
  field         String
  previousValue String?
  newValue      String?
  createdAt     DateTime       @default(now())
  snapshot      RosterSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  character     Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
  @@index([snapshotId])
}

model InventoryChange {
  id              String         @id @default(cuid())
  snapshotId      String
  inventoryItemId String
  externalId      String
  field           String
  previousValue   String?
  newValue        String?
  createdAt       DateTime       @default(now())
  snapshot        RosterSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId, createdAt])
  @@index([snapshotId])
}
